# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/online_egitim_platformu

# MongoDB connection pool settings
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_WAIT_QUEUE_TIMEOUT_MS=3000
MONGO_HEARTBEAT_FREQUENCY_MS=10000
DB_CONNECT_RETRIES=3
DB_RETRY_BASE_DELAY_MS=1000

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret-at-least-64-chars
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173
